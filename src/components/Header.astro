---
import HeaderLink from './HeaderLink.astro';
import { SITE_TITLE } from '../consts';
---

<header>
	<nav>
		<a href="/" class="site-title">{SITE_TITLE}</a>
		<input type="checkbox" id="nav-toggle" class="nav-toggle" aria-hidden="true" />
		<label for="nav-toggle" class="nav-toggle-label" aria-label="Åpne meny">
			<span></span>
			<span></span>
			<span></span>
		</label>
		<div class="nav-links">
			<HeaderLink href="/">Hjem</HeaderLink>
			<HeaderLink href="/cv">CV</HeaderLink>
			<HeaderLink href="/about">Om meg</HeaderLink>
			<HeaderLink href="/blog">Blogg</HeaderLink>
			<HeaderLink href="/github">GitHub prosjekter</HeaderLink>
			<a
				href="https://github.com/matskkolstad"
				target="_blank"
				rel="noopener noreferrer"
				class="github-link"
				aria-label="GitHub-profil"
			>
				<svg viewBox="0 0 16 16" aria-hidden="true" width="22" height="22">
					<path
						fill="currentColor"
						d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.012 8.012 0 0 0 16 8c0-4.42-3.58-8-8-8z"
					></path>
				</svg>
			</a>
		</div>
	</nav>
</header>

<style>
	header {
		position: sticky;
		top: 0;
		z-index: 100;
		background: rgba(255, 255, 255, 0.95);
		backdrop-filter: blur(8px);
		-webkit-backdrop-filter: blur(8px);
		border-bottom: 1px solid rgb(var(--gray-light));
	}
	nav {
		display: flex;
		align-items: center;
		gap: 0.5em;
		max-width: 1000px;
		margin: 0 auto;
		padding: 0 1.5em;
		height: 60px;
	}
	.site-title {
		font-weight: 700;
		font-size: 1.1rem;
		color: rgb(var(--black));
		text-decoration: none;
		flex-shrink: 0;
		transition: color var(--transition);
	}
	.site-title:hover {
		color: var(--accent);
		text-decoration: none;
	}
	.nav-links {
		display: flex;
		align-items: center;
		gap: 0.25em;
		margin-left: auto;
	}
	.nav-links :global(a) {
		padding: 0.4em 0.75em;
		border-radius: 6px;
		color: rgb(var(--gray-dark));
		font-size: 0.95rem;
		text-decoration: none;
		transition: background var(--transition), color var(--transition);
		border-bottom: none;
	}
	.nav-links :global(a:hover),
	.nav-links :global(a.active) {
		color: var(--accent);
		background: var(--accent-light);
		text-decoration: none;
		border-bottom: none;
	}
	.github-link {
		display: flex;
		align-items: center;
		padding: 0.4em !important;
		margin-left: 0.25em;
		color: rgb(var(--gray-dark)) !important;
		border-radius: 6px;
	}
	.github-link:hover {
		color: var(--accent) !important;
		background: var(--accent-light) !important;
	}

	/* Hamburger */
	.nav-toggle {
		display: none;
	}
	.nav-toggle-label {
		display: none;
		flex-direction: column;
		gap: 5px;
		cursor: pointer;
		margin-left: auto;
		padding: 0.4em;
	}
	.nav-toggle-label span {
		display: block;
		width: 22px;
		height: 2px;
		background: rgb(var(--black));
		border-radius: 2px;
		transition: var(--transition);
	}

	@media (max-width: 640px) {
		.nav-toggle-label {
			display: flex;
		}
		.nav-links {
			display: none;
			position: absolute;
			top: 60px;
			left: 0;
			right: 0;
			background: rgba(255, 255, 255, 0.98);
			border-bottom: 1px solid rgb(var(--gray-light));
			flex-direction: column;
			align-items: stretch;
			padding: 0.75em 1.5em;
			gap: 0.25em;
		}
		.nav-links :global(a) {
			padding: 0.6em 0.75em;
		}
		.nav-toggle:checked ~ .nav-links {
			display: flex;
		}
		.nav-toggle:checked ~ .nav-toggle-label span:nth-child(1) {
			transform: rotate(45deg) translate(5px, 5px);
		}
		.nav-toggle:checked ~ .nav-toggle-label span:nth-child(2) {
			opacity: 0;
		}
		.nav-toggle:checked ~ .nav-toggle-label span:nth-child(3) {
			transform: rotate(-45deg) translate(5px, -5px);
		}
	}
</style>

