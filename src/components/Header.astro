---
import HeaderLink from './HeaderLink.astro';
import { SITE_TITLE } from '../consts';
---

<header>
	<nav>
		<h2><a href="/">{SITE_TITLE}</a></h2>
		<div class="internal-links">
			<HeaderLink href="/">Hjem</HeaderLink>
			<HeaderLink href="/#cv">CV</HeaderLink>
			<HeaderLink href="/#kompetanse">Kompetanse</HeaderLink>
			<HeaderLink href="/#prosjekter">Prosjekter</HeaderLink>
			<HeaderLink href="/about">Om meg</HeaderLink>
		</div>
		<div class="social-links">
			<a class="pill" href="mailto:hei@kjoshagen.online">
				<span class="sr-only">Send e-post</span>
				<svg viewBox="0 0 24 24" aria-hidden="true" width="24" height="24">
					<path
						fill="currentColor"
						d="M4 6c-1.1 0-2 .9-2 2v8c0 1.1.9 2 2 2h16c1.1 0 2-.9 2-2V8c0-1.1-.9-2-2-2H4zm0 2 8 5 8-5v2l-8 5-8-5V8z"
					></path>
				</svg>
			</a>
			<a class="pill" href="https://www.linkedin.com/in/kjoshagen" target="_blank" rel="noreferrer">
				<span class="sr-only">LinkedIn</span>
				<svg viewBox="0 0 24 24" aria-hidden="true" width="24" height="24">
					<path
						fill="currentColor"
						d="M20.452 20.452h-3.554v-5.57c0-1.328-.027-3.037-1.85-3.037-1.851 0-2.134 1.445-2.134 2.938v5.669H9.36V9h3.414v1.561h.049c.476-.9 1.637-1.85 3.369-1.85 3.604 0 4.271 2.372 4.271 5.459v6.282zM5.337 7.433a2.065 2.065 0 1 1 .001-4.13 2.065 2.065 0 0 1-.001 4.13zm1.777 13.019H3.56V9h3.554v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0z"
					></path>
				</svg>
			</a>
			<a class="pill" href="https://github.com/matskkolstad" target="_blank" rel="noreferrer">
				<span class="sr-only">GitHub</span>
				<svg viewBox="0 0 16 16" aria-hidden="true" width="24" height="24"
					><path
						fill="currentColor"
						d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.012 8.012 0 0 0 16 8c0-4.42-3.58-8-8-8z"
					></path></svg
				>
			</a>
		</div>
	</nav>
</header>
<style>
	header {
		margin: 0;
		padding: 0 1em;
		background: rgba(255, 255, 255, 0.9);
		backdrop-filter: blur(8px);
		position: sticky;
		top: 0;
		z-index: 10;
		border-bottom: 1px solid rgba(var(--gray-light), 0.6);
	}
	h2 {
		margin: 0;
		font-size: 1em;
	}

	h2 a,
	h2 a.active {
		text-decoration: none;
	}
	nav {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 1rem;
	}
	nav a {
		padding: 1em 0.5em;
		color: var(--black);
		border-bottom: 4px solid transparent;
		text-decoration: none;
		font-weight: 600;
	}
	nav a.active {
		text-decoration: none;
		border-bottom-color: var(--accent);
	}
	.social-links {
		display: flex;
		gap: 0.5rem;
		align-items: center;
	}
	.pill {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		gap: 0.35rem;
		padding: 0.45rem 0.7rem;
		border-radius: 999px;
		border: 1px solid rgba(var(--gray), 0.35);
		background: white;
		color: rgb(var(--black));
		box-shadow: 0 2px 8px rgba(var(--gray), 0.16);
	}
	.pill:hover {
		border-color: var(--accent);
		color: var(--accent);
		box-shadow: 0 8px 18px rgba(var(--accent-rgb, 35, 55, 255), 0.18);
	}
	@media (max-width: 720px) {
		.social-links {
			display: none;
		}
	}
</style>
