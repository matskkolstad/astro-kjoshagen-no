---
import HeaderLink from './HeaderLink.astro';
import { SITE_TITLE } from '../consts';
---

<header>
	<nav>
		<div class="brand">
			<h2><a href="/">{SITE_TITLE}</a></h2>
			<p class="tagline">Sky, backend og brukeropplevelse</p>
		</div>
		<div class="internal-links">
			<HeaderLink href="/">Hjem</HeaderLink>
			<HeaderLink href="/#about">Om meg</HeaderLink>
			<HeaderLink href="/#cv">CV</HeaderLink>
			<HeaderLink href="/#skills">Kompetanse</HeaderLink>
			<HeaderLink href="/#projects">Prosjekter</HeaderLink>
			<HeaderLink href="/#contact">Kontakt</HeaderLink>
		</div>
		<div class="social-links">
			<a href="mailto:hello@kjoshagen.online">
				<span class="sr-only">Send e-post</span>
				<svg viewBox="0 0 24 24" aria-hidden="true" width="28" height="28"
					><path
						fill="currentColor"
						d="M4 4h16a2 2 0 0 1 2 2v12a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V6a2 2 0 0 1 2-2zm0 2v.511l8 4.889 8-4.89V6H4zm0 2.489V18h16V8.489l-8 4.889-8-4.889z"
					></path></svg
				>
			</a>
			<a href="https://github.com/matskkolstad" target="_blank" rel="noreferrer">
				<span class="sr-only">GitHub</span>
				<svg viewBox="0 0 16 16" aria-hidden="true" width="28" height="28"
					><path
						fill="currentColor"
						d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.012 8.012 0 0 0 16 8c0-4.42-3.58-8-8-8z"
					></path></svg
				>
			</a>
		</div>
	</nav>
</header>
<style>
	header {
		margin: 0;
		padding: 0.5em 1.5em;
		background: rgba(255, 255, 255, 0.94);
		backdrop-filter: blur(8px);
		box-shadow: 0 12px 30px rgba(var(--gray), 14%);
		position: sticky;
		top: 0;
		z-index: 10;
	}

	h2 {
		margin: 0;
		font-size: 1em;
		letter-spacing: 0.02em;
	}

	h2 a,
	h2 a.active {
		text-decoration: none;
		color: rgb(var(--black));
	}
	nav {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 1rem;
	}
	nav a {
		padding: 1em 0.5em;
		color: var(--black);
		border-bottom: 4px solid transparent;
		text-decoration: none;
		font-weight: 600;
	}
	nav a.active {
		text-decoration: none;
		border-bottom-color: var(--accent);
	}
	.brand {
		display: flex;
		flex-direction: column;
		gap: 0.15rem;
	}
	.tagline {
		margin: 0;
		font-size: 0.8em;
		color: rgb(var(--gray));
	}
	.social-links,
	.social-links a {
		display: flex;
	}
	.social-links {
		gap: 0.75em;
		align-items: center;
	}
	.social-links a {
		color: rgb(var(--black));
		padding: 0.35em;
		border-radius: 999px;
		border: 1px solid rgba(var(--gray), 30%);
		background: rgba(255, 255, 255, 0.7);
	}
	.social-links a:hover {
		color: rgb(var(--accent-dark));
		border-color: rgba(var(--accent), 50%);
	}
	.internal-links {
		display: flex;
		gap: 0.25em;
		align-items: center;
	}
	@media (max-width: 720px) {
		.social-links {
			display: none;
		}
		nav {
			flex-direction: column;
			align-items: flex-start;
		}
		.internal-links {
			flex-wrap: wrap;
		}
	}
</style>
