---
import HeaderLink from './HeaderLink.astro';
import { CV_LINK, SITE_TITLE } from '../consts';
---

<header class="site-header">
	<div class="inner">
		<a class="brand" href="/">
			<span class="dot" aria-hidden="true"></span>
			<div class="brand-text">
				<span class="name">{SITE_TITLE}</span>
				<span class="tagline">Produkt · teknologi · leveranser</span>
			</div>
		</a>
		<nav class="links">
			<HeaderLink href="/#profile">Profil</HeaderLink>
			<HeaderLink href="/#experience">Erfaring</HeaderLink>
			<HeaderLink href="/#projects">Prosjekter</HeaderLink>
			<HeaderLink href="/#contact">Kontakt</HeaderLink>
			<HeaderLink href="/blog">Blogg</HeaderLink>
		</nav>
		<div class="actions">
			<a class="ghost" href={CV_LINK}>Last ned CV</a>
			<a class="primary" href="/#contact">La oss prate</a>
		</div>
	</div>
</header>
<style>
	.site-header {
		position: sticky;
		top: 0.5rem;
		z-index: 10;
		margin: 0 auto 1.25rem;
		width: min(1200px, calc(100% - 2rem));
	}
	.inner {
		display: grid;
		grid-template-columns: auto 1fr auto;
		align-items: center;
		gap: 1rem;
		padding: 0.85rem 1.25rem;
		border-radius: 18px;
		background: linear-gradient(120deg, rgba(14, 165, 233, 0.08), rgba(14, 165, 233, 0.02));
		border: 1px solid rgba(255, 255, 255, 0.08);
		backdrop-filter: blur(12px);
		box-shadow: 0 15px 50px rgba(2, 6, 23, 0.45);
	}
	.brand {
		display: inline-flex;
		align-items: center;
		gap: 0.75rem;
		text-decoration: none;
		color: #f8fbff;
		font-weight: 700;
	}
	.dot {
		width: 12px;
		height: 12px;
		border-radius: 50%;
		background: radial-gradient(circle, #22c55e 0%, #0ea5e9 80%);
		box-shadow: 0 0 0 8px rgba(14, 165, 233, 0.15);
		animation: pulse 6s ease-in-out infinite;
	}
	.brand-text {
		display: flex;
		flex-direction: column;
		line-height: 1.1;
	}
	.name {
		font-size: 1.05rem;
		letter-spacing: -0.01em;
	}
	.tagline {
		font-size: 0.85rem;
		color: var(--muted);
	}
	.links {
		display: inline-flex;
		justify-content: center;
		gap: 0.8rem;
	}
	.links a {
		color: var(--text);
		font-weight: 600;
		padding: 0.5rem 0.75rem;
		border-radius: 12px;
		text-decoration: none;
		transition: background 140ms ease, transform 140ms ease;
	}
	.links a:hover {
		background: rgba(255, 255, 255, 0.06);
		transform: translateY(-1px);
	}
	.links a.active {
		background: rgba(255, 255, 255, 0.08);
		color: #f8fbff;
	}
	.actions {
		display: inline-flex;
		align-items: center;
		gap: 0.6rem;
	}
	.actions a {
		display: inline-flex;
		align-items: center;
		gap: 0.35rem;
		font-weight: 700;
		border-radius: 12px;
		padding: 0.55rem 0.85rem;
		border: 1px solid rgba(255, 255, 255, 0.12);
		text-decoration: none;
		transition: transform 140ms ease, box-shadow 140ms ease, border-color 140ms ease;
	}
	.actions .primary {
		background: linear-gradient(120deg, #0ea5e9, #22c55e);
		color: #041019;
		border-color: transparent;
		box-shadow: 0 10px 30px rgba(14, 165, 233, 0.35);
	}
	.actions .primary:hover {
		transform: translateY(-1px) scale(1.01);
		box-shadow: 0 15px 40px rgba(14, 165, 233, 0.4);
	}
	.actions .ghost {
		color: var(--text);
		background: rgba(255, 255, 255, 0.04);
	}
	.actions .ghost:hover {
		border-color: rgba(255, 255, 255, 0.2);
		transform: translateY(-1px);
	}
	@keyframes pulse {
		0%,
		100% {
			box-shadow: 0 0 0 8px rgba(14, 165, 233, 0.15);
		}
		50% {
			box-shadow: 0 0 0 16px rgba(14, 165, 233, 0.05);
		}
	}
	@media (max-width: 900px) {
		.inner {
			grid-template-columns: 1fr;
			row-gap: 0.6rem;
			align-items: start;
		}
		.links {
			flex-wrap: wrap;
			justify-content: flex-start;
		}
		.actions {
			justify-content: flex-start;
		}
	}
</style>
