---
import { CONTACT_EMAIL, CV_LINK, SITE_TITLE } from '../consts';

const year = new Date().getFullYear();
---

<footer class="footer card">
	<div class="primary">
		<p class="eyebrow">Tilgjengelig for spennende oppdrag</p>
		<h3>{SITE_TITLE}</h3>
		<p>
			Bygger stabile produkter som tåler trafikk, og følger dem helt fra idé til produksjon.
			Fokus på tydelig kommunikasjon, rask leveranse og god teknisk kvalitet.
		</p>
		<div class="chips">
			<span>Cloudflare & serverless</span>
			<span>TypeScript/Node</span>
			<span>Plattform & DevOps</span>
		</div>
	</div>
	<div class="links">
		<p class="eyebrow">Snarveier</p>
		<a href={CV_LINK}>Last ned CV (plassholder)</a>
		<a href="/blog">Blogg og notater</a>
		<a href="/#projects">Prosjekter</a>
	</div>
	<div class="contact">
		<p class="eyebrow">Kontakt</p>
		<a href={`mailto:${CONTACT_EMAIL}`}>
			<svg viewBox="0 0 24 24" aria-hidden="true" focusable="false">
				<path
					fill="currentColor"
					d="M20.5 5h-17A1.5 1.5 0 0 0 2 6.5v11A1.5 1.5 0 0 0 3.5 19h17a1.5 1.5 0 0 0 1.5-1.5v-11A1.5 1.5 0 0 0 20.5 5Zm-.3 2-7.58 5.05a1.1 1.1 0 0 1-1.24 0L3.8 7Z"
				></path>
			</svg>
			{CONTACT_EMAIL}
		</a>
		<a href="https://www.linkedin.com" target="_blank" rel="noreferrer">
			<svg viewBox="0 0 24 24" aria-hidden="true" focusable="false">
				<path
					fill="currentColor"
					d="M6.94 9H4.06v11h2.88zM5.5 4a1.67 1.67 0 1 0 0 3.34A1.67 1.67 0 0 0 5.5 4ZM20 20v-6.19c0-3.32-1.78-4.87-4.15-4.87a3.59 3.59 0 0 0-3.24 1.78h-.05V9H9.8v11h2.89v-5.89c0-1.55.29-3.05 2.22-3.05s2 1.72 2 3.15V20Z"
				></path>
			</svg>
			LinkedIn (oppdater lenke)
		</a>
		<a href="https://github.com" target="_blank" rel="noreferrer">
			<svg viewBox="0 0 24 24" aria-hidden="true" focusable="false">
				<path
					fill="currentColor"
					d="M12 2a10 10 0 0 0-3.16 19.49c.5.09.68-.22.68-.49v-1.7c-2.78.6-3.37-1.2-3.37-1.2a2.65 2.65 0 0 0-1.1-1.46c-.9-.61.07-.6.07-.6a2.1 2.1 0 0 1 1.52 1 2.12 2.12 0 0 0 2.9.83 2.11 2.11 0 0 1 .63-1.33c-2.22-.26-4.56-1.11-4.56-4.94a3.86 3.86 0 0 1 1-2.68 3.59 3.59 0 0 1 .1-2.65s.84-.27 2.75 1a9.34 9.34 0 0 1 5 0c1.9-1.26 2.74-1 2.74-1a3.6 3.6 0 0 1 .1 2.65 3.85 3.85 0 0 1 1 2.68c0 3.85-2.34 4.67-4.58 4.92a2.35 2.35 0 0 1 .67 1.81v2.69c0 .27.18.59.69.49A10 10 0 0 0 12 2Z"
				></path>
			</svg>
			GitHub (oppdater lenke)
		</a>
	</div>
	<div class="meta">
		<span>© {year} {SITE_TITLE}. Klar for neste samtale.</span>
	</div>
</footer>
<style>
	.footer {
		display: grid;
		grid-template-columns: 2fr 1fr 1fr;
		gap: 1.5rem;
		padding: 1.75rem;
		margin: 3rem auto 1rem;
		border-radius: 18px;
		background: linear-gradient(145deg, rgba(14, 165, 233, 0.08), rgba(10, 16, 32, 0.9));
		border: 1px solid rgba(255, 255, 255, 0.08);
	}
	.eyebrow {
		text-transform: uppercase;
		letter-spacing: 0.08em;
		font-size: 0.75rem;
		color: var(--muted);
		margin: 0 0 0.35rem;
	}
	h3 {
		margin: 0 0 0.4rem;
		font-size: 1.6rem;
	}
	p {
		margin: 0 0 0.75rem;
		color: var(--muted);
	}
	.chips {
		display: flex;
		flex-wrap: wrap;
		gap: 0.5rem;
		margin-top: 0.5rem;
	}
	.chips span {
		padding: 0.45rem 0.75rem;
		border-radius: 12px;
		background: rgba(255, 255, 255, 0.06);
		color: var(--text);
		border: 1px solid rgba(255, 255, 255, 0.08);
		font-weight: 600;
	}
	.links,
	.contact {
		display: flex;
		flex-direction: column;
		gap: 0.6rem;
	}
	a {
		text-decoration: none;
		color: var(--text);
		display: inline-flex;
		align-items: center;
		gap: 0.6rem;
		font-weight: 600;
		transition: color 140ms ease, transform 140ms ease;
	}
	a:hover {
		color: var(--accent-contrast);
		transform: translateX(2px);
	}
	svg {
		width: 18px;
		height: 18px;
	}
	.meta {
		grid-column: 1 / -1;
		display: flex;
		justify-content: space-between;
		align-items: center;
		border-top: 1px solid rgba(255, 255, 255, 0.08);
		padding-top: 1rem;
		color: var(--muted);
		font-size: 0.95rem;
	}
	@media (max-width: 960px) {
		.footer {
			grid-template-columns: 1fr;
		}
		.meta {
			flex-direction: column;
			gap: 0.5rem;
			align-items: flex-start;
		}
	}
</style>
