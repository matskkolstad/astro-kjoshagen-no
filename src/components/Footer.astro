---
const today = new Date();
---

<footer>
	<div class="footer-grid">
		<div>
			<p class="eyebrow">K. Joshagen</p>
			<p>Bygger raske, stabile løsninger på web og i skyen med fokus på produktfart og kvalitet.</p>
		</div>
		<div class="footer-links">
			<p class="eyebrow">Kontakt</p>
			<a href="mailto:hello@kjoshagen.online">hello@kjoshagen.online</a>
			<a href="https://github.com/matskkolstad" target="_blank" rel="noreferrer">GitHub</a>
		</div>
		<div class="footer-links">
			<p class="eyebrow">Snarveier</p>
			<a href="/#cv">CV</a>
			<a href="/#projects">Prosjekter</a>
			<a href="/#contact">Kontakt</a>
		</div>
	</div>
	<p class="copyright">&copy; {today.getFullYear()} K. Joshagen. Alt innhold er personlig.</p>
</footer>
<style>
	footer {
		padding: 3em 1em 4em 1em;
		background: linear-gradient(180deg, rgba(var(--gray-light), 50%) 0%, #ffffff 60%);
		color: rgb(var(--gray-dark));
		text-align: left;
	}
	.footer-grid {
		width: 960px;
		max-width: calc(100% - 2em);
		margin: 0 auto;
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
		gap: 1.5em;
	}
	.footer-links {
		display: flex;
		flex-direction: column;
		gap: 0.35em;
	}
	.footer-links a {
		text-decoration: none;
		color: rgb(var(--black));
		font-weight: 600;
	}
	.footer-links a:hover {
		color: rgb(var(--accent));
	}
	.eyebrow {
		text-transform: uppercase;
		letter-spacing: 0.08em;
		font-size: 0.75em;
		color: rgb(var(--gray));
		margin: 0 0 0.35em 0;
	}
	.copyright {
		width: 960px;
		max-width: calc(100% - 2em);
		margin: 2em auto 0 auto;
		color: rgb(var(--gray));
		font-size: 0.9em;
	}
</style>
