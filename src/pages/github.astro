---
import PageLayout from '../layouts/PageLayout.astro';

interface GitHubRepo {
	id: number;
	name: string;
	full_name: string;
	html_url: string;
	description: string | null;
	language: string | null;
	stargazers_count: number;
	forks_count: number;
	open_issues_count: number;
	updated_at: string;
	pushed_at: string;
	topics: string[];
	homepage: string | null;
	fork: boolean;
	archived: boolean;
	visibility: string;
}

let repos: GitHubRepo[] = [];
let fetchError = false;

async function fetchAllPublicRepos(username: string): Promise<GitHubRepo[]> {
	const perPage = 100;
	let page = 1;
	const allRepos: GitHubRepo[] = [];

	while (true) {
		const response = await fetch(
			`https://api.github.com/users/${username}/repos?sort=updated&per_page=${perPage}&type=public&page=${page}`,
			{
				headers: {
					'Accept': 'application/vnd.github+json',
					'X-GitHub-Api-Version': '2022-11-28',
					'User-Agent': 'kjoshagen.no',
				},
			}
		);

		if (!response.ok) {
			throw new Error(`GitHub API request failed with status ${response.status}`);
		}

		const pageRepos: GitHubRepo[] = await response.json();
		allRepos.push(...pageRepos);

		if (pageRepos.length < perPage) {
			break;
		}

		page += 1;
	}

	return allRepos;
}

try {
	const data = await fetchAllPublicRepos('matskkolstad');
	repos = data.filter((r) => !r.fork && !r.archived);
} catch {
	fetchError = true;
}

function formatDate(dateStr: string): string {
	const date = new Date(dateStr);
	return date.toLocaleDateString('nb-NO', { year: 'numeric', month: 'long', day: 'numeric' });
}
---

<PageLayout title="GitHub prosjekter – Mats Kjoshagen Kolstad" description="Offentlige GitHub-prosjekter av Mats Kjoshagen Kolstad, automatisk oppdatert og sortert etter siste aktivitet.">
	<style>
		.page-header {
			padding-bottom: 2em;
			border-bottom: 1px solid rgb(var(--gray-light));
			margin-bottom: 2.5em;
			display: flex;
			align-items: flex-start;
			justify-content: space-between;
			flex-wrap: wrap;
			gap: 1em;
		}
		.page-header h1 {
			margin-bottom: 0.25em;
		}
		.page-header .subtitle {
			font-size: 1.05rem;
			color: rgb(var(--gray));
			margin: 0;
		}
		.github-profile-link {
			display: inline-flex;
			align-items: center;
			gap: 0.5em;
			color: var(--accent);
			font-weight: 600;
			font-size: 0.9rem;
			text-decoration: none;
			border: 1px solid rgba(29,78,216,0.25);
			border-radius: 6px;
			padding: 0.4em 0.9em;
			transition: background var(--transition), border-color var(--transition);
			white-space: nowrap;
		}
		.github-profile-link:hover {
			background: var(--accent-light);
			border-color: rgba(29,78,216,0.45);
			text-decoration: none;
		}

		.repos-grid {
			display: grid;
			grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
			gap: 1.25em;
		}
		.repo-card {
			background: rgb(var(--white));
			border: 1px solid rgb(var(--gray-light));
			border-radius: var(--radius);
			padding: 1.5em;
			display: flex;
			flex-direction: column;
			gap: 0.6em;
			box-shadow: var(--box-shadow);
			transition: box-shadow var(--transition), transform var(--transition), border-color var(--transition);
			text-decoration: none;
			color: inherit;
		}
		.repo-card:hover {
			box-shadow: var(--box-shadow-hover);
			transform: translateY(-3px);
			border-color: rgba(29,78,216,0.25);
			text-decoration: none;
		}
		.repo-name {
			font-size: 1rem;
			font-weight: 700;
			color: var(--accent);
			margin: 0;
			display: flex;
			align-items: center;
			gap: 0.4em;
		}
		.repo-desc {
			font-size: 0.875rem;
			color: rgb(var(--gray));
			margin: 0;
			line-height: 1.5;
			flex: 1;
		}
		.repo-meta {
			display: flex;
			flex-wrap: wrap;
			gap: 0.6em;
			align-items: center;
			margin-top: auto;
			padding-top: 0.5em;
			border-top: 1px solid rgb(var(--gray-light));
		}
		.repo-lang {
			display: flex;
			align-items: center;
			gap: 0.3em;
			font-size: 0.8rem;
			font-weight: 600;
			color: rgb(var(--gray-dark));
		}
		.lang-dot {
			width: 10px;
			height: 10px;
			border-radius: 50%;
			background: var(--accent);
			flex-shrink: 0;
		}
		.repo-stat {
			display: flex;
			align-items: center;
			gap: 0.25em;
			font-size: 0.8rem;
			color: rgb(var(--gray));
		}
		.repo-updated {
			font-size: 0.75rem;
			color: rgb(var(--gray));
			margin-left: auto;
		}
		.repo-topics {
			display: flex;
			flex-wrap: wrap;
			gap: 0.35em;
		}
		.repo-topic {
			background: var(--accent-light);
			color: var(--accent);
			border-radius: 100px;
			padding: 0.15em 0.6em;
			font-size: 0.75rem;
			font-weight: 600;
		}
		.repo-homepage {
			font-size: 0.8rem;
			color: var(--accent);
			text-decoration: none;
			display: inline-flex;
			align-items: center;
			gap: 0.25em;
		}
		.repo-homepage:hover { text-decoration: underline; }

		.error-box {
			padding: 2em;
			text-align: center;
			background: rgb(var(--surface));
			border: 1px solid rgb(var(--gray-light));
			border-radius: var(--radius);
			color: rgb(var(--gray));
		}
		.repo-count {
			font-size: 0.85rem;
			color: rgb(var(--gray));
			margin-bottom: 1.5em;
		}
	</style>

	<div class="page-header">
		<div>
			<h1>GitHub prosjekter</h1>
			<p class="subtitle">Offentlige prosjekter – automatisk oppdatert, sortert etter siste aktivitet</p>
		</div>
		<a
			href="https://github.com/matskkolstad"
			target="_blank"
			rel="noopener noreferrer"
			class="github-profile-link"
		>
			<svg viewBox="0 0 16 16" aria-hidden="true" width="16" height="16">
				<path fill="currentColor" d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.012 8.012 0 0 0 16 8c0-4.42-3.58-8-8-8z"/>
			</svg>
			github.com/matskkolstad
		</a>
	</div>

	{fetchError ? (
		<div class="error-box">
			<p>Kunne ikke hente prosjekter fra GitHub akkurat nå. Prøv igjen senere eller besøk <a href="https://github.com/matskkolstad" target="_blank" rel="noopener noreferrer">github.com/matskkolstad</a> direkte.</p>
		</div>
	) : repos.length === 0 ? (
		<div class="error-box">
			<p>Ingen offentlige prosjekter funnet.</p>
		</div>
	) : (
		<>
			<p class="repo-count">{repos.length} offentlige prosjekter</p>
			<div class="repos-grid">
				{repos.map((repo) => (
					<a href={repo.html_url} target="_blank" rel="noopener noreferrer" class="repo-card">
						<p class="repo-name">
							<svg viewBox="0 0 16 16" aria-hidden="true" width="16" height="16" style="flex-shrink:0">
								<path fill="currentColor" d="M2 2.5A2.5 2.5 0 0 1 4.5 0h8.75a.75.75 0 0 1 .75.75v12.5a.75.75 0 0 1-.75.75h-2.5a.75.75 0 0 1 0-1.5h1.75v-2h-8a1 1 0 0 0-.714 1.7.75.75 0 1 1-1.072 1.05A2.495 2.495 0 0 1 2 11.5Zm10.5-1h-8a1 1 0 0 0-1 1v6.708A2.486 2.486 0 0 1 4.5 9h8Z"/>
							</svg>
							{repo.name}
						</p>
						{repo.description && (
							<p class="repo-desc">{repo.description}</p>
						)}
						{repo.topics.length > 0 && (
							<div class="repo-topics">
								{repo.topics.slice(0, 5).map((topic) => (
									<span class="repo-topic">{topic}</span>
								))}
							</div>
						)}
						{repo.homepage && (
							<span class="repo-homepage">
								🌐 {repo.homepage.replace(/^https?:\/\//, '')}
							</span>
						)}
						<div class="repo-meta">
							{repo.language && (
								<span class="repo-lang">
									<span class="lang-dot" aria-hidden="true"></span>
									{repo.language}
								</span>
							)}
							{repo.stargazers_count > 0 && (
								<span class="repo-stat" title="Stjerner">
									⭐ {repo.stargazers_count}
								</span>
							)}
							{repo.forks_count > 0 && (
								<span class="repo-stat" title="Forks">
									🍴 {repo.forks_count}
								</span>
							)}
							<span class="repo-updated">
								Oppdatert {formatDate(repo.pushed_at)}
							</span>
						</div>
					</a>
				))}
			</div>
		</>
	)}
</PageLayout>
