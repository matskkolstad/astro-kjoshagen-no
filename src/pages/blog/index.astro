---
import BaseHead from '../../components/BaseHead.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { SITE_TITLE } from '../../consts';
import { getCollection } from 'astro:content';
import FormattedDate from '../../components/FormattedDate.astro';

const posts = (await getCollection('blog')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
---

<!doctype html>
<html lang="no">
	<head>
		<BaseHead title={`Blogg – ${SITE_TITLE}`} description="Artikler og tanker om teknologi, utvikling og IT fra Mats Kjoshagen." />
		<style>
			.page-header {
				padding-bottom: 1.5em;
				border-bottom: 1px solid rgb(var(--gray-light));
				margin-bottom: 2.5em;
			}
			.page-header h1 { margin-bottom: 0.25em; }
			.page-header p { color: rgb(var(--gray)); margin: 0; }

			.posts-grid {
				display: grid;
				grid-template-columns: 1fr;
				gap: 1.5em;
			}
			.post-card {
				display: grid;
				grid-template-columns: 220px 1fr;
				gap: 0;
				border: 1px solid rgb(var(--gray-light));
				border-radius: var(--radius);
				overflow: hidden;
				box-shadow: var(--box-shadow);
				text-decoration: none;
				color: inherit;
				transition: box-shadow var(--transition), transform var(--transition), border-color var(--transition);
				background: rgb(var(--white));
			}
			.post-card:hover {
				box-shadow: var(--box-shadow-hover);
				transform: translateY(-2px);
				border-color: rgba(29,78,216,0.25);
				text-decoration: none;
			}
			.post-card img {
				width: 100%;
				height: 100%;
				object-fit: cover;
				border-radius: 0;
				display: block;
			}
			.post-card-body {
				padding: 1.25em 1.5em;
				display: flex;
				flex-direction: column;
				justify-content: center;
				gap: 0.4em;
			}
			.post-date {
				font-size: 0.8rem;
				color: rgb(var(--gray));
				font-weight: 600;
				text-transform: uppercase;
				letter-spacing: 0.04em;
			}
			.post-title {
				font-size: 1.15rem;
				font-weight: 700;
				color: rgb(var(--black));
				margin: 0;
				line-height: 1.3;
			}
			.post-desc {
				font-size: 0.875rem;
				color: rgb(var(--gray));
				margin: 0;
				line-height: 1.5;
			}
			.post-read-more {
				font-size: 0.8rem;
				font-weight: 700;
				color: var(--accent);
				margin-top: 0.25em;
			}

			@media (max-width: 640px) {
				.post-card {
					grid-template-columns: 1fr;
				}
				.post-card img {
					height: 160px;
				}
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			<div class="page-header">
				<h1>Blogg</h1>
				<p>Tanker, erfaringer og tekniske artikler om IT og utvikling.</p>
			</div>

			{posts.length === 0 ? (
				<p style="color:rgb(var(--gray))">Ingen innlegg ennå. Kom tilbake snart!</p>
			) : (
				<div class="posts-grid">
					{posts.map((post) => (
						<a href={`/blog/${post.id}/`} class="post-card">
							{post.data.heroImage && (
								<img src={post.data.heroImage} alt="" width={440} height={220} />
							)}
							<div class="post-card-body">
								<span class="post-date"><FormattedDate date={post.data.pubDate} /></span>
								<p class="post-title">{post.data.title}</p>
								{post.data.description && (
									<p class="post-desc">{post.data.description}</p>
								)}
								<span class="post-read-more">Les mer →</span>
							</div>
						</a>
					))}
				</div>
			)}
		</main>
		<Footer />
	</body>
</html>

