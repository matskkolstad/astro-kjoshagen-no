---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from '../consts';
---

<!doctype html>
<html lang="no">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
		<style>
			/* Hero */
			.hero {
				padding: 5em 0 3.5em;
				text-align: center;
				position: relative;
			}
			.hero::before {
				content: '';
				position: absolute;
				inset: 0;
				background: radial-gradient(ellipse 80% 60% at 50% 0%, rgba(29, 78, 216, 0.07) 0%, transparent 70%);
				pointer-events: none;
			}
			.hero-badge {
				display: inline-block;
				background: var(--accent-light);
				color: var(--accent);
				border: 1px solid rgba(29,78,216,0.2);
				border-radius: 100px;
				font-size: 0.85rem;
				font-weight: 700;
				padding: 0.3em 1em;
				margin-bottom: 1.25em;
				letter-spacing: 0.03em;
				text-transform: uppercase;
			}
			.hero h1 {
				font-size: clamp(2.25rem, 6vw, 3.5rem);
				line-height: 1.1;
				margin-bottom: 0.5em;
				background: linear-gradient(135deg, rgb(var(--black)) 40%, var(--accent));
				-webkit-background-clip: text;
				-webkit-text-fill-color: transparent;
				background-clip: text;
			}
			.hero-tagline {
				font-size: 1.15rem;
				color: rgb(var(--gray));
				max-width: 520px;
				margin: 0 auto 2em;
				line-height: 1.6;
			}
			.hero-actions {
				display: flex;
				gap: 1em;
				justify-content: center;
				flex-wrap: wrap;
			}

			/* Divider */
			.section-divider {
				display: flex;
				align-items: center;
				gap: 1em;
				margin: 3em 0 1.75em;
			}
			.section-divider::before,
			.section-divider::after {
				content: '';
				flex: 1;
				height: 1px;
				background: rgb(var(--gray-light));
			}
			.section-divider span {
				font-size: 0.8rem;
				font-weight: 700;
				text-transform: uppercase;
				letter-spacing: 0.08em;
				color: rgb(var(--gray));
				white-space: nowrap;
			}

			/* Skills */
			.skills-grid {
				display: flex;
				flex-wrap: wrap;
				gap: 0.6em;
				list-style: none;
				padding: 0;
				margin: 0;
			}
			.skill-tag {
				background: rgb(var(--surface));
				border: 1px solid rgb(var(--gray-light));
				border-radius: 100px;
				padding: 0.35em 1em;
				font-size: 0.875rem;
				color: rgb(var(--gray-dark));
				font-weight: 600;
				transition: background var(--transition), border-color var(--transition), color var(--transition);
			}
			.skill-tag:hover {
				background: var(--accent-light);
				border-color: rgba(29,78,216,0.3);
				color: var(--accent);
			}

			/* Feature cards */
			.cards-grid {
				display: grid;
				grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
				gap: 1.25em;
				margin-top: 1em;
			}
			.feature-card {
				background: rgb(var(--white));
				border: 1px solid rgb(var(--gray-light));
				border-radius: var(--radius);
				padding: 1.5em;
				text-decoration: none;
				color: inherit;
				display: flex;
				flex-direction: column;
				gap: 0.5em;
				box-shadow: var(--box-shadow);
				transition: box-shadow var(--transition), transform var(--transition), border-color var(--transition);
			}
			.feature-card:hover {
				box-shadow: var(--box-shadow-hover);
				transform: translateY(-3px);
				border-color: rgba(29,78,216,0.25);
				text-decoration: none;
			}
			.card-icon {
				font-size: 1.75rem;
				line-height: 1;
			}
			.card-title {
				font-size: 1.05rem;
				font-weight: 700;
				color: rgb(var(--black));
				margin: 0;
			}
			.card-desc {
				font-size: 0.875rem;
				color: rgb(var(--gray));
				margin: 0;
				line-height: 1.5;
			}

			/* Contact strip */
			.contact-strip {
				margin-top: 1.25em;
				padding: 1.5em;
				background: linear-gradient(135deg, var(--accent-light) 0%, rgba(219,234,254,0.5) 100%);
				border: 1px solid rgba(29,78,216,0.15);
				border-radius: var(--radius);
				display: flex;
				align-items: center;
				justify-content: space-between;
				flex-wrap: wrap;
				gap: 1em;
			}
			.contact-strip p {
				margin: 0;
				font-weight: 600;
				color: rgb(var(--black));
			}
			.contact-strip span {
				display: block;
				font-size: 0.875rem;
				font-weight: 400;
				color: rgb(var(--gray));
				margin-top: 0.2em;
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			<section class="hero">
				<div class="hero-badge">Tilgjengelig for nye muligheter</div>
				<h1>Mats Kjoshagen</h1>
				<p class="hero-tagline">
					IT-utvikler med lidenskap for teknologi, kode og gode løsninger –
					fra frontend til sky og alt i mellom.
				</p>
				<div class="hero-actions">
					<a href="/cv" class="btn btn-primary">📄 Se min CV</a>
					<a href="/about" class="btn btn-secondary">Om meg</a>
				</div>
			</section>

			<div class="section-divider"><span>Tekniske ferdigheter</span></div>

			<ul class="skills-grid">
				<li class="skill-tag">TypeScript</li>
				<li class="skill-tag">JavaScript</li>
				<li class="skill-tag">Python</li>
				<li class="skill-tag">React</li>
				<li class="skill-tag">Node.js</li>
				<li class="skill-tag">Astro</li>
				<li class="skill-tag">SQL / PostgreSQL</li>
				<li class="skill-tag">REST API</li>
				<li class="skill-tag">Docker</li>
				<li class="skill-tag">Linux</li>
				<li class="skill-tag">Git</li>
				<li class="skill-tag">Cloudflare</li>
				<li class="skill-tag">Azure</li>
				<li class="skill-tag">HTML / CSS</li>
			</ul>

			<div class="section-divider"><span>Utforsk</span></div>

			<div class="cards-grid">
				<a href="/cv" class="feature-card">
					<div class="card-icon">📄</div>
					<p class="card-title">Curriculum Vitae</p>
					<p class="card-desc">Erfaring, utdanning og tekniske kvalifikasjoner samlet på ett sted.</p>
				</a>
				<a href="/about" class="feature-card">
					<div class="card-icon">👤</div>
					<p class="card-title">Om meg</p>
					<p class="card-desc">Hvem er jeg, hva driver meg, og hva ser jeg etter?</p>
				</a>
				<a href="/blog" class="feature-card">
					<div class="card-icon">✍️</div>
					<p class="card-title">Blogg</p>
					<p class="card-desc">Tanker, erfaringer og tekniske artikler om det jeg jobber med.</p>
				</a>
				<a href="https://github.com/matskkolstad" target="_blank" rel="noopener noreferrer" class="feature-card">
					<div class="card-icon">🐙</div>
					<p class="card-title">GitHub</p>
					<p class="card-desc">Se mine open source-prosjekter og bidrag på GitHub.</p>
				</a>
			</div>

			<div class="contact-strip">
				<div>
					<p>La oss ta en prat!</p>
					<span>Jeg er alltid åpen for interessante samtaler og muligheter.</span>
				</div>
				<a href="mailto:mats@kjoshagen.online" class="btn btn-primary">Ta kontakt</a>
			</div>
		</main>
		<Footer />
	</body>
</html>


