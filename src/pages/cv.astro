---
import PageLayout from '../layouts/PageLayout.astro';
---

<PageLayout title="CV – Mats Kjoshagen" description="Curriculum Vitae for Mats Kjoshagen – erfaring, utdanning og tekniske ferdigheter.">
	<style>
		/* Print styles */
		@media print {
			.print-hide { display: none !important; }
			.cv-header { padding-bottom: 1em; }
			.cv-section { break-inside: avoid; }
			body { font-size: 12pt; }
		}

		.cv-header {
			padding-bottom: 2em;
			border-bottom: 2px solid var(--accent);
			margin-bottom: 2.5em;
			display: flex;
			justify-content: space-between;
			align-items: flex-start;
			flex-wrap: wrap;
			gap: 1.5em;
		}
		.cv-name {
			font-size: 2.25rem;
			font-weight: 700;
			color: rgb(var(--black));
			margin: 0 0 0.2em;
			background: linear-gradient(135deg, rgb(var(--black)) 30%, var(--accent));
			-webkit-background-clip: text;
			-webkit-text-fill-color: transparent;
			background-clip: text;
		}
		.cv-title {
			font-size: 1.1rem;
			color: rgb(var(--gray));
			margin: 0;
		}
		.cv-contact {
			display: flex;
			flex-direction: column;
			gap: 0.4em;
			font-size: 0.9rem;
			text-align: right;
		}
		.cv-contact a {
			color: var(--accent);
			text-decoration: none;
			display: flex;
			align-items: center;
			gap: 0.4em;
			justify-content: flex-end;
		}
		.cv-contact a:hover { text-decoration: underline; }

		/* Section */
		.cv-section {
			margin-bottom: 2.5em;
		}
		.cv-section-title {
			font-size: 0.75rem;
			font-weight: 700;
			text-transform: uppercase;
			letter-spacing: 0.1em;
			color: var(--accent);
			border-bottom: 2px solid rgb(var(--gray-light));
			padding-bottom: 0.4em;
			margin-bottom: 1.25em;
		}

		/* Timeline */
		.timeline {
			display: flex;
			flex-direction: column;
			gap: 1.5em;
		}
		.timeline-item {
			display: grid;
			grid-template-columns: 1fr auto;
			gap: 0 1.5em;
			padding-bottom: 1.5em;
			border-bottom: 1px solid rgb(var(--gray-light));
		}
		.timeline-item:last-child {
			border-bottom: none;
			padding-bottom: 0;
		}
		.timeline-org {
			font-weight: 700;
			font-size: 1rem;
			color: rgb(var(--black));
			margin: 0 0 0.1em;
		}
		.timeline-role {
			font-size: 0.95rem;
			color: rgb(var(--gray));
			margin: 0 0 0.5em;
		}
		.timeline-desc {
			font-size: 0.9rem;
			color: rgb(var(--gray-dark));
			margin: 0;
			line-height: 1.6;
		}
		.timeline-desc ul {
			margin: 0.4em 0 0;
			padding-left: 1.25em;
		}
		.timeline-desc li {
			margin-bottom: 0.25em;
		}
		.timeline-period {
			font-size: 0.8rem;
			color: rgb(var(--gray));
			white-space: nowrap;
			background: rgb(var(--surface));
			border: 1px solid rgb(var(--gray-light));
			border-radius: 100px;
			padding: 0.2em 0.8em;
			height: fit-content;
			font-weight: 600;
		}

		/* Skills */
		.skills-categories {
			display: grid;
			grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
			gap: 1.25em;
		}
		.skill-category h4 {
			font-size: 0.85rem;
			font-weight: 700;
			text-transform: uppercase;
			letter-spacing: 0.06em;
			color: rgb(var(--gray));
			margin: 0 0 0.6em;
		}
		.skill-pills {
			display: flex;
			flex-wrap: wrap;
			gap: 0.4em;
		}
		.skill-pill {
			background: rgb(var(--surface));
			border: 1px solid rgb(var(--gray-light));
			border-radius: 100px;
			padding: 0.25em 0.75em;
			font-size: 0.8rem;
			color: rgb(var(--gray-dark));
			font-weight: 600;
		}

		/* Languages */
		.lang-list {
			display: flex;
			flex-direction: column;
			gap: 0.75em;
		}
		.lang-item {
			display: flex;
			align-items: center;
			justify-content: space-between;
		}
		.lang-name {
			font-weight: 600;
			color: rgb(var(--black));
			font-size: 0.95rem;
		}
		.lang-level {
			display: flex;
			align-items: center;
			gap: 0.5em;
		}
		.lang-dots {
			display: flex;
			gap: 4px;
		}
		.lang-dot {
			width: 10px;
			height: 10px;
			border-radius: 50%;
			background: rgb(var(--gray-light));
		}
		.lang-dot.filled {
			background: var(--accent);
		}
		.lang-label {
			font-size: 0.8rem;
			color: rgb(var(--gray));
		}

		/* Print button */
		.print-btn {
			margin-bottom: 2em;
			display: flex;
			justify-content: flex-end;
		}
		.print-btn button {
			background: transparent;
			border: 1px solid rgb(var(--gray-light));
			border-radius: 6px;
			padding: 0.4em 1em;
			font-size: 0.85rem;
			cursor: pointer;
			color: rgb(var(--gray));
			display: flex;
			align-items: center;
			gap: 0.4em;
			transition: background var(--transition), color var(--transition);
		}
		.print-btn button:hover {
			background: rgb(var(--surface));
			color: rgb(var(--black));
		}

		@media (max-width: 560px) {
			.cv-header { flex-direction: column; }
			.cv-contact { text-align: left; }
			.cv-contact a { justify-content: flex-start; }
			.timeline-item { grid-template-columns: 1fr; }
			.timeline-period { width: fit-content; }
		}
	</style>

	<div class="print-btn print-hide">
		<button onclick="window.print()">🖨️ Skriv ut / Lagre som PDF</button>
	</div>

	<header class="cv-header">
		<div>
			<h1 class="cv-name">Mats Kjoshagen Kolstad</h1>
			<p class="cv-title">Overingeniør · Sesongleder · IT-drift &amp; Support</p>
		</div>
		<address class="cv-contact">
			<a href="mailto:kjoshagenkolstad@icloud.com">📧 kjoshagenkolstad@icloud.com</a>
			<a href="tel:+4794127232">📱 +47 941 27 232</a>
			<a href="https://github.com/matskkolstad" target="_blank" rel="noopener noreferrer">🐙 github.com/matskkolstad</a>
			<a href="https://kjoshagen.no" target="_blank" rel="noopener noreferrer">🌐 kjoshagen.no</a>
			<a href="https://www.linkedin.com/in/matskkolstad" target="_blank" rel="noopener noreferrer">💼 LinkedIn</a>
			<span style="color:rgb(var(--gray));font-size:0.85rem">📍 Oslo</span>
		</address>
	</header>

	<!-- Summary -->
	<section class="cv-section">
		<h2 class="cv-section-title">Sammendrag</h2>
		<p>
			IT-driftstekniker med solid erfaring fra brukerstøtte, systemadministrasjon og prosjektledelse.
			Kompetanse innen Windows Server-miljøer, virtualisering (VMware/Proxmox) og brukerdokumentasjon.
			Praktisk orientert og opptatt av å levere god brukeropplevelse gjennom tydelig kommunikasjon
			og effektiv problemløsning.
		</p>
	</section>

	<!-- Experience -->
	<section class="cv-section">
		<h2 class="cv-section-title">Arbeidserfaring</h2>
		<div class="timeline">
			<div class="timeline-item">
				<div>
					<p class="timeline-org">Universitetet i Oslo</p>
					<p class="timeline-role">Overingeniør – Windows Applikasjonsdrift</p>
					<div class="timeline-desc">
						<ul>
							<li>Drift av EduKiosk (terminalbaserte applikasjonstjenester) som leverer Felles Studentsystem, Økonomisystem (Unit4/UBW) og Tableau til utdanningssektoren.</li>
							<li>Ansvarlig for drift, vedlikehold og support til UiOs utskriftssystem.</li>
							<li>Drift av Programkiosk for studenter og ansatte ved UiO.</li>
							<li>Ukesvakter med overvåking i Zabbix og håndtering av systemalarmer.</li>
							<li>Kommunikasjon med andre seksjoner, førstelinje og eksterne kunder via RT-ticket-system.</li>
							<li>Utvikling av brukerdokumentasjon og veiledninger.</li>
						</ul>
					</div>
				</div>
				<span class="timeline-period">Nov 2023 – nå</span>
			</div>

			<div class="timeline-item">
				<div>
					<p class="timeline-org">Universitetet i Oslo</p>
					<p class="timeline-role">Avdelingsingeniør – IT-hjelp</p>
					<div class="timeline-desc">
						<ul>
							<li>Første kontaktpunkt for IT-hjelp med ansvar for 7 200 ansatte og 26 000 studenter.</li>
							<li>Løsning av IT-relaterte spørsmål via ticket-system, chat og telefon.</li>
							<li>Erfaring med UiOs IT-systemer: nettskjema, programkiosk m.m.</li>
							<li>Samarbeid med andre/tredje-linje ved behov.</li>
						</ul>
					</div>
				</div>
				<span class="timeline-period">Okt 2022 – Nov 2023</span>
			</div>

			<div class="timeline-item">
				<div>
					<p class="timeline-org">Dyreparken Kristiansand</p>
					<p class="timeline-role">Sesongleder – IT-support</p>
					<div class="timeline-desc">
						<ul>
							<li>Leder for IT-support team (4–5 ansatte) under høysesong.</li>
							<li>Personaloppfølging, vaktplanlegging og opplæring.</li>
							<li>Ansvarlig for IT-drift for rundt 1 000 sesongansatte.</li>
							<li>Drift av kassesystem (Yonoton), fotosystem (PomVom) og nettverk.</li>
							<li>Håndtering av henvendelser via telefon og Asana-ticket-system.</li>
						</ul>
					</div>
				</div>
				<span class="timeline-period">Mars 2020 – nå</span>
			</div>
		</div>
	</section>

	<!-- Education -->
	<section class="cv-section">
		<h2 class="cv-section-title">Utdanning</h2>
		<div class="timeline">
			<div class="timeline-item">
				<div>
					<p class="timeline-org">Universitetet i Oslo</p>
					<p class="timeline-role">Master – Informatikk: Design, bruk, interaksjon</p>
					<p class="timeline-desc">
						Forståelse om hvordan dagens datasystemer fungerer i praksis, og bruk av kunnskap til å skape morgendagens IT-løsninger.
						Fullført alle emner på masternivå; valgte å fokusere på praktisk erfaring gjennom arbeid fremfor å skrive masteroppgave.
					</p>
				</div>
				<span class="timeline-period">Aug 2022 – Nov 2025</span>
			</div>

			<div class="timeline-item">
				<div>
					<p class="timeline-org">Universitetet i Agder</p>
					<p class="timeline-role">Bachelor – IT og Informasjonssystemer</p>
					<p class="timeline-desc">
						Studiet omhandler hvordan man kan bidra til å utvikle informasjonssystemer og hvordan digitalisering påvirker samfunnet.
					</p>
				</div>
				<span class="timeline-period">Aug 2019 – Juni 2022</span>
			</div>
		</div>
	</section>

	<!-- Projects -->
	<section class="cv-section">
		<h2 class="cv-section-title">Prosjekter</h2>
		<div class="timeline">
			<div class="timeline-item">
				<div>
					<p class="timeline-org">PaperCut UiO</p>
					<p class="timeline-role">Utskifting av utskriftssystem</p>
					<div class="timeline-desc">
						<ul>
							<li>Sentral deltaker i utskifting av hele UiOs utskriftssystem.</li>
							<li>Ansvarlig for installasjon av rundt 150 nye skrivere på tvers av alle campuser, samt konvertering av rundt 150–200 eldre skrivere.</li>
							<li>Oppsett av DNS-registrering, skriverkø og nettverksdelegering.</li>
							<li>Tett samarbeid med interne IT-ressurser for vellykket implementering.</li>
						</ul>
					</div>
				</div>
				<span class="timeline-period">Nov 2023 – Mai 2024</span>
			</div>
		</div>
	</section>

	<!-- Volunteer -->
